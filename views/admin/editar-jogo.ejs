<%- include('../partials/head', { title: 'Editar Jogo' }) %>
<%- include('../partials/navbar', { user }) %>

<main class="container" style="max-width:680px">
  <a href="/admin/painel?aba=jogos" class="back-link">← Voltar ao painel</a>

  <div class="card">
    <h1 class="page-title" style="font-size:1.4rem">✏️ Editar Jogo</h1>

    <% if (erro) { %>
      <div class="alert alert-error"><%= erro %></div>
    <% } %>

    <form method="POST" action="/admin/jogo/<%= jogo.id %>/editar?_csrf=<%= csrfToken %>" enctype="multipart/form-data">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="form-group">
          <label for="nome">Nome do jogo *</label>
          <input type="text" id="nome" name="nome" value="<%= jogo.nome %>" required />
        </div>
        <div class="form-group">
          <label for="categoria">Categoria *</label>
          <select id="categoria" name="categoria" required>
            <option value="matematica" <%= jogo.categoria === 'matematica' ? 'selected' : '' %>>➕ Matemática</option>
            <option value="leitura" <%= jogo.categoria === 'leitura' ? 'selected' : '' %>>📖 Leitura / Escrita</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label for="conteudos">Conteúdos trabalhados *</label>
        <textarea id="conteudos" name="conteudos" required><%= jogo.conteudos %></textarea>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="form-group">
          <label for="ano">Ano escolar *</label>
          <input type="text" id="ano" name="ano" value="<%= jogo.ano %>" required />
        </div>
        <div class="form-group">
          <label for="link_jogo">Link do jogo (URL) *</label>
          <input type="url" id="link_jogo" name="link_jogo" value="<%= jogo.link_jogo %>" required />
        </div>
      </div>
      <div class="form-group">
        <label>Ícone atual</label>
        <% if (jogo.icone_url) { %>
          <div style="margin-bottom:.75rem">
            <img src="<%= jogo.icone_url %>" alt="ícone atual" style="width:72px;height:72px;object-fit:contain;border-radius:10px;border:1px solid #B8DFF5" />
          </div>
        <% } else { %>
          <p class="form-hint" style="margin-bottom:.75rem">Nenhum ícone definido.</p>
        <% } %>
        <label for="icone">Substituir ícone (opcional, máx. 2 MB)</label>
        <input type="file" id="icone" name="icone" accept="image/*" />
      </div>
      <div class="form-group">
        <label for="icone_url_manual">URL da imagem (alternativa ao upload)</label>
        <input type="url" id="icone_url_manual" name="icone_url_manual" value="<%= jogo.icone_url && !jogo.icone_url.startsWith('/uploads') ? jogo.icone_url : '' %>" placeholder="https://exemplo.com/icone.png" />
      </div>
      <div style="display:flex;gap:1rem;align-items:center">
        <button type="submit" class="btn btn-primary">💾 Salvar Alterações</button>
        <a href="/admin/painel?aba=jogos" class="btn btn-outline">Cancelar</a>
      </div>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>
